{%- style -%}
  .features-banner-wrapper {
    padding: 0 var(--page-padding, 1.5rem);
    max-width: var(--page-width, 1400px);
    margin: 40px auto;
  }
  .features-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: {{ section.settings.background_color }};
    border-radius: 8px;
    padding: 32px 40px;
    gap: 24px;
    flex-wrap: wrap;
  }
  .features-banner__item {
    display: flex;
    align-items: center;
    gap: 16px;
    flex: 1;
    min-width: 200px;
  }
  .features-banner__icon-wrapper {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .features-banner__icon-wrapper img {
    width: 24px;
    height: 24px;
    object-fit: contain;
  }
  .features-banner__icon-wrapper svg {
    width: 24px;
    height: 24px;
    fill: none;
    stroke: {{ section.settings.text_color }};
    stroke-width: 1.5;
  }
  .features-banner__text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .features-banner__title {
    margin: 0;
    font-size: 14px;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    line-height: 1.2;
  }
  .features-banner__description {
    margin: 0;
    font-size: 12px;
    color: {{ section.settings.text_color }};
    opacity: 0.7;
    line-height: 1.4;
  }

  @media screen and (max-width: 768px) {
    .features-banner {
      flex-direction: column;
      align-items: flex-start;
      padding: 24px;
    }
    .features-banner__item {
      width: 100%;
    }
  }
{%- endstyle -%}

<div class="features-banner-wrapper">
  <div class="features-banner">
    {%- for block in section.blocks -%}
      <div class="features-banner__item" {{ block.shopify_attributes }}>
        <div class="features-banner__icon-wrapper" style="background-color: {{ section.settings.icon_bg_color }};">
          {%- if block.settings.icon != blank -%}
            {{ block.settings.icon | image_url: width: 48 | image_tag: loading: 'lazy' }}
          {%- else -%}
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
               <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5" fill="none"/>
               <path d="M12 8v4l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {%- endif -%}
        </div>
        <div class="features-banner__text">
          {%- if block.settings.title != blank -%}
            <h3 class="features-banner__title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="features-banner__description">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Features Banner",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#e6edf6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#11203b"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Icon Background Color",
      "default": "#c9d8eb"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image",
          "info": "Upload a transparent PNG or SVG for the icon."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Short description of the feature."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features Banner",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Engineered for Comfort",
            "description": "Soft, breathable & moisture-wicking"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Performance Stretch",
            "description": "Four-way stretch for unlimited movement"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Functional Design",
            "description": "Pockets where you need them most"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Trusted by Nurses",
            "description": "10,000+ healthcare professionals"
          }
        }
      ]
    }
  ]
}
{% endschema %}
